# ─────────────────────────────────────────────────────────────────
# SolarPro Financial — Environment Variables Template
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# ── Stripe Billing ────────────────────────────────────────────────
# Get your keys from: https://dashboard.stripe.com/apikeys
# Leave blank to run in DEMO mode (no real payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (create products in Stripe dashboard first)
# Monthly recurring prices for Pro and Enterprise plans
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ── Exchange Rate API ─────────────────────────────────────────────
# Free key from: https://exchangerate.host (optional)
# App uses public endpoint without key; add key for higher rate limits
EXCHANGERATE_API_KEY=

# ── App Settings ──────────────────────────────────────────────────
# Set to "production" when deploying publicly
APP_ENV=development
